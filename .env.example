# Configuracion de Firebase
# Copie este archivo a .env y complete con sus credenciales de Firebase
# Vite usa VITE_ prefix

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Integracion servidor SICAR -> Firebase (usar Firebase Admin SDK)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# MySQL SICAR (solo lectura)
SICAR_MYSQL_HOST=127.0.0.1
SICAR_MYSQL_PORT=3306
SICAR_MYSQL_USER=readonly_user
SICAR_MYSQL_PASSWORD=readonly_password
SICAR_MYSQL_DATABASE=sicar

# Opcionales de integracion
SICAR_SYNC_LOOKBACK_DAYS=7
SICAR_SYNC_BATCH_SIZE=250
SICAR_SYNC_LOG_DIR=logs/sicar-sync
SICAR_SYNC_WRITE_INVENTORY_CACHE=false
